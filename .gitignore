# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
secrets.yaml
Tab5/user_entities.yaml

# Bytecode Python (composants ESPHome custom)
__pycache__/
*.pyc

# Ignorer les scripts de l'IA et tests locaux
/ia_tools_scripts/
/archives/
config_out.txt
test_*.yaml

# Logs
*.log
home-assistant_*.log

# Configurations et logs locaux ESPHome
config_dump.yaml
esphome_live_logs.txt
HomeAssistant_Config/automations_examples.yaml.example
HomeAssistant_Config/automations_tab5.yaml
HomeAssistant_Config/scripts_tab5.yaml
HomeAssistant_Config/template_sensors_meteo_tab5.yaml
Tab5/tts_library/
Tab5/tts_library_v2/
