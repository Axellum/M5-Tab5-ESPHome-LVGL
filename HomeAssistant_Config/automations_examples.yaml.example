# ============================================================================
# [AI-CONTEXT]
# @file automations_examples.yaml.example (généré depuis automations_tab5.yaml)
# @role Automatisations HA qui poussent les données vers le Tab5 (push-only, cf.
#       Tab5/README.md côté firmware).
# @architecture_constraint Chaque `action: esphome.tab5_ha_hmi_tab5_maj_*` correspond à
#       un service `api: services:` déclaré dans 00ProjetTab/Tab5/tab5-api-logic.yaml.
#       Ne JAMAIS renommer un service ici sans renommer le pendant firmware (et
#       vice-versa) — sinon la poussée échoue silencieusement (pas d'erreur HA visible).
# @payload_contract Les payloads bulk (jours/heures/pluie 1h/alerte météo) sont des
#       chaînes délimitées par `;`/`|` — le format doit matcher EXACTEMENT ce que
#       parse_and_update_*_bulk() (tab5_custom.cpp) attend en nombre de champs.
# @ai_instruction `delay: 1s` entre les blocs + `delay: 150ms`/`50ms` dans les boucles
#       ne sont PAS du remplissage : ils évitent de saturer le socket TCP de l'ESP32-P4
#       en même temps que le flux audio I2S actif. Ne pas les retirer pour "accélérer".
# @ai_warning `now()` ne doit JAMAIS être passé brut à un service HA (`{{ now() }}`) —
#       toujours via `.strftime(...)` explicite. Un datetime brut (microsecondes
#       incluses) peut casser silencieusement toute la suite de l'automation.
# @ai_instruction `continue_on_error: true` + les gardes `is defined else []` sur
#       `daily_var`/`hourly_var_tab5` évitent qu'un échec ponctuel de `calendar.get_events`
#       ou `weather.get_forecasts` (API externe temporairement indisponible) ne bloque
#       tout le reste de la poussée écran.
# ============================================================================

- alias: "MAJ Ecran Tab5 ESPHome Push"
  mode: single
  id: tab5_ha_hmi_updater
  trigger:
    - platform: state
      entity_id: weather.VOTRE_VILLE
    - platform: state
      entity_id: climate.VOTRE_CLIMATISATION
    - platform: state
      entity_id: sensor.VOTRE_VILLE_next_rain
    - platform: state
      entity_id: sensor.phrase_prochaine_pluie
    - platform: time_pattern
      minutes: "/10"
    - platform: event
      event_type: esphome.tab5_connected
    - platform: state
      entity_id: calendar.VOTRE_EMAIL_gmail_com

  action:
    # ====== 1. MISE A JOUR MINUTE PAR MINUTE DE LA PHRASE PLUIE ET ALERTES ======
    - action: esphome.tab5_ha_hmi_tab5_maj_alerte_meteo_france
      continue_on_error: true
      data:
        payload: >
          {{ states('sensor.phrase_prochaine_pluie') }}|{{ states('sensor.40_weather_alert') | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Vent violent') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Crues') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Orages') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Pluie-inondation') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Neige-verglas') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Grand-froid') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Vagues-submersion') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Canicule') | default('Vert', true) | capitalize }}|{{ state_attr('sensor.40_weather_alert', 'Avalanches') | default('Vert', true) | capitalize }}


    # ====== 2. INTERRUPTION SI C'EST JUSTE LE REBOURS MINUTE ======
    - condition: template
      value_template: >
        {{ trigger.platform != 'state' or trigger.entity_id != 'sensor.phrase_prochaine_pluie' }}

    # ====== 3. METEO ACTUELLE ======
    - action: esphome.tab5_ha_hmi_tab5_maj_meteo_actuelle
      continue_on_error: true
      data:
        condition: "{{ states('weather.VOTRE_VILLE') }}"
        temperature: "{{ state_attr('weather.VOTRE_VILLE', 'temperature') | float(0) }}"
        humidite: "{{ state_attr('weather.VOTRE_VILLE', 'humidity') | float(0) }}"
    - delay: "00:00:01"

    # ====== 4. PROBABILITES ======
    - action: esphome.tab5_ha_hmi_tab5_maj_probabilites
      continue_on_error: true
      data:
        uv: "{{ states('sensor.VOTRE_VILLE_uv') | int(0) }}"
        gel: "{{ states('sensor.VOTRE_VILLE_freeze_chance') | int(0) }}"
        neige: "{{ states('sensor.VOTRE_VILLE_snow_chance') | int(0) }}"

    # ====== 4b. METEO PLUIE 1H (9 barres : 0,5,10,15,20,25 puis 35,45,55) ======
    - repeat:
        count: 9
        sequence:
          - action: esphome.tab5_ha_hmi_tab5_maj_pluie_1h
            continue_on_error: true
            data:
              index_5mn: "{{ repeat.index - 1 }}"
              intensite: >
                {% set fc = state_attr('sensor.VOTRE_VILLE_next_rain', '1_hour_forecast') %}
                {% set keys = ['0 min', '5 min', '10 min', '15 min', '20 min', '25 min', '35 min', '45 min', '55 min'] %}
                {% set k = keys[repeat.index - 1] %}
                {{ fc.get(k, 'Inconnu') if fc is not none else 'Inconnu' }}
          - delay:
              milliseconds: 50

    # ====== 5. PREVISIONS JOURS (BULK - 1 seul appel au lieu de 15) ======
    - action: calendar.get_events
      continue_on_error: true
      data:
        start_date_time: "{{ now().strftime('%Y-%m-%d 00:00:00') }}"
        end_date_time: "{{ (now() + timedelta(days=15)).strftime('%Y-%m-%d 23:59:59') }}"
      target:
        entity_id: calendar.VOTRE_EMAIL_gmail_com
      response_variable: agenda_events
    - action: weather.get_forecasts
      continue_on_error: true
      data:
        type: daily
      target:
        entity_id: weather.VOTRE_VILLE
      response_variable: daily_var
    - action: esphome.tab5_ha_hmi_tab5_maj_previsions_jours_bulk
      continue_on_error: true
      data:
        payload: >
          {% set fcasts = daily_var.get('weather.VOTRE_VILLE', {}).get('forecast', []) if daily_var is defined else [] %}
          {% set days_names = ["Dim", "Lun", "Mar", "Mer", "Jeu", "Ven", "Sam"] %}
          {% set ns = namespace(result="") %}
          {% for i in range(15) %}
            {% set target_dt = now() + timedelta(days=i) %}
            {% set target_date = target_dt.strftime('%Y-%m-%d') %}
            {% if i == 0 %}
              {% set nom_jour = "Auj " ~ target_dt.strftime('%d') %}
            {% else %}
              {% set nom_jour = days_names[target_dt.strftime('%w') | int] ~ " " ~ target_dt.strftime('%d') %}
            {% endif %}
            {% set condition = fcasts[i].condition | default('unknown') if i < fcasts|length else 'unknown' %}
            {% set tmin = fcasts[i].templow | float(0) if i < fcasts|length else 0 %}
            {% set tmax = fcasts[i].temperature | float(0) if i < fcasts|length else 0 %}
            {% set est_passe = 'false' if i < fcasts|length else 'true' %}
            {% set est_dimanche = target_dt.strftime('%w') == '0' %}
            {% set ns_travail = namespace(found=false, heures="") %}
            {% if agenda_events['calendar.VOTRE_EMAIL_gmail_com'] is defined %}
              {% for event in agenda_events['calendar.VOTRE_EMAIL_gmail_com'].events %}
                {% set ev_start = event.start | default(event.start_time, '') | string %}
                {% set ev_end = event.end | default(event.end_time, '') | string %}
                {% set ev_msg = event.summary | default(event.message, '') | string %}
                {% if target_date in ev_start or target_date in ev_end %}
                  {% if 'Travail' in ev_msg %}
                    {% set ns_travail.found = true %}
                    {% if target_date in ev_start %}
                      {% set start_dt = ev_start | as_datetime %}
                      {% set end_dt = ev_end | as_datetime %}
                      {% set ns_travail.heures = start_dt.strftime('%H:%M') ~ "-" ~ end_dt.strftime('%H:%M') %}
                    {% endif %}
                  {% endif %}
                {% endif %}
              {% endfor %}
            {% endif %}
            {% set est_repos = not ns_travail.found %}
            {% set ns.result = ns.result ~ i ~ "|" ~ nom_jour ~ "|" ~ condition ~ "|" ~ tmin ~ "|" ~ tmax ~ "|" ~ ("1" if est_repos else "0") ~ "|" ~ ("1" if est_dimanche else "0") ~ "|" ~ ("1" if est_passe == 'true' else "0") ~ "|" ~ ns_travail.heures ~ ";" %}
          {% endfor %}
          {{ ns.result }}

    # ====== 6. CLIMATISATION ======
    - action: esphome.tab5_ha_hmi_tab5_maj_clim
      continue_on_error: true
      data:
        target: "{{ state_attr('climate.VOTRE_CLIMATISATION', 'temperature') | float(20) }}"
        current: "{{ state_attr('climate.VOTRE_CLIMATISATION', 'current_temperature') | float(20) }}"
        mode: "{{ states('climate.VOTRE_CLIMATISATION') }}"
        preset: "{{ state_attr('climate.VOTRE_CLIMATISATION', 'preset_mode') | default('none', true) }}"
        fan: "{{ state_attr('climate.VOTRE_CLIMATISATION', 'fan_mode') | default('auto', true) }}"
        swing: "{{ state_attr('climate.VOTRE_CLIMATISATION', 'swing_mode') | default('off', true) }}"

    # ====== X. ETAT VOLET ======
    - action: esphome.tab5_ha_hmi_tab5_maj_volet_etat
      continue_on_error: true
      data:
        etat_physique: >
          {% if is_state('input_boolean.volet_serre_mouvement', 'on') %}
            En_mouvement
          {% else %}
            {{ states('input_text.volet_serre_etat') }}
          {% endif %}

    # ====== Y. PLANNING HORAIRE (TEXTE TAB5) ======
    - action: esphome.tab5_ha_hmi_tab5_maj_planning
      continue_on_error: true
      data:
        ligne1: >
          {% set ns = namespace(lignes=[]) %}
          {% set now_dt = now() %}
          {% if agenda_events['calendar.VOTRE_EMAIL_gmail_com'] is defined %}
            {% for event in agenda_events['calendar.VOTRE_EMAIL_gmail_com'].events %}
              {% if 'Travail' in event.summary|default(event.message, '') %}
                {% set start_dt = event.start | as_datetime %}
                {% set end_dt = event.end | as_datetime %}
                
                {% set is_auj = start_dt.date() == now_dt.date() %}
                {% set is_demain = start_dt.date() == (now_dt + timedelta(days=1)).date() %}
                
                {% if is_auj %}
                  {% set j_name = "Auj." %}
                {% elif is_demain %}
                  {% set j_name = "Dem." %}
                {% else %}
                  {% set j_name = ["Dim.","Lun.","Mar.","Mer.","Jeu.","Ven.","Sam."][start_dt.strftime('%w')|int] %}
                {% endif %}

                {% set em = start_dt.strftime('%H:%M') %}
                {% set de = end_dt.strftime('%H:%M') %}
                {% set is_early = start_dt.hour < 9 %}
                {% set hex = "ff8888" if is_early else "ffffff" %}
                
                {% if is_demain %}
                  {% set j_name_colored = "#44aaff " ~ j_name ~ "#" %}
                {% else %}
                  {% set j_name_colored = "#" ~ hex ~ " " ~ j_name ~ "#" %}
                {% endif %}
                
                {% set line_str = (ns.lignes|length + 1)|string ~ "/ " ~ j_name_colored ~ " : #" ~ hex ~ " " ~ em ~ "-" ~ de ~ "#" %}
                
                {% if is_auj %}
                   {% if now_dt.timestamp() < start_dt.timestamp() %}
                      {% set ns.lignes = ns.lignes + [line_str] %}
                   {% endif %}
                {% elif start_dt.date() > now_dt.date() %}
                   {% set ns.lignes = ns.lignes + [line_str] %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {{ ns.lignes[0] if ns.lignes|length > 0 else "#aaaaaa Aucun travail de prevu#" }}
        ligne2: >
          {% set ns = namespace(lignes=[]) %}
          {% set now_dt = now() %}
          {% if agenda_events['calendar.VOTRE_EMAIL_gmail_com'] is defined %}
            {% for event in agenda_events['calendar.VOTRE_EMAIL_gmail_com'].events %}
              {% if 'Travail' in event.summary|default(event.message, '') %}
                {% set start_dt = event.start | as_datetime %}
                {% set end_dt = event.end | as_datetime %}
                
                {% set is_auj = start_dt.date() == now_dt.date() %}
                {% set is_demain = start_dt.date() == (now_dt + timedelta(days=1)).date() %}
                
                {% if is_auj %}
                  {% set j_name = "Auj." %}
                {% elif is_demain %}
                  {% set j_name = "Dem." %}
                {% else %}
                  {% set j_name = ["Dim.","Lun.","Mar.","Mer.","Jeu.","Ven.","Sam."][start_dt.strftime('%w')|int] %}
                {% endif %}

                {% set em = start_dt.strftime('%H:%M') %}
                {% set de = end_dt.strftime('%H:%M') %}
                {% set is_early = start_dt.hour < 9 %}
                {% set hex = "ff8888" if is_early else "ffffff" %}
                
                {% if is_demain %}
                  {% set j_name_colored = "#44aaff " ~ j_name ~ "#" %}
                {% else %}
                  {% set j_name_colored = "#" ~ hex ~ " " ~ j_name ~ "#" %}
                {% endif %}
                
                {% set line_str = (ns.lignes|length + 1)|string ~ "/ " ~ j_name_colored ~ " : #" ~ hex ~ " " ~ em ~ "-" ~ de ~ "#" %}
                
                {% if is_auj %}
                   {% if now_dt.timestamp() < start_dt.timestamp() %}
                      {% set ns.lignes = ns.lignes + [line_str] %}
                   {% endif %}
                {% elif start_dt.date() > now_dt.date() %}
                   {% set ns.lignes = ns.lignes + [line_str] %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {{ ns.lignes[1] if ns.lignes|length > 1 else "" }}

    # ====== 7. ZONE D'INFO (CALENDRIER ET ALERTES) ======
    - action: esphome.tab5_ha_hmi_tab5_maj_info_texte
      continue_on_error: true
      data:
        texte: >
          {% set alerte = states('sensor.VOTRE_DEPARTEMENT_weather_alert') %}
          {% if alerte == 'Rouge' or alerte == 'Orange' %}
             Alerte Météo {{ alerte }} en cours ! Restez prudent.
          {% else %}
            {% set ns = namespace(texte="") %}
            {% set days = ["Dim.", "Lun.", "Mar.", "Mer.", "Jeu.", "Ven.", "Sam."] %}
            {% for i in range(0, 3) %}
               {% set target_dt = now() + timedelta(days=i) %}
               {% set target_str = target_dt.strftime('%Y-%m-%d') %}
               {% set j_name = "Auj." if i == 0 else ("Dem." if i == 1 else days[target_dt.strftime('%w')|int]) %}
               
               {% set travail = false %}
               {% set em = "" %}
               {% set de = "" %}
               {% if agenda_events['calendar.VOTRE_EMAIL_gmail_com'] is defined %}
                 {% for event in agenda_events['calendar.VOTRE_EMAIL_gmail_com'].events %}
                   {% set ev_start = event.start | default(event.start_time, '') | string %}
                   {% set ev_end = event.end | default(event.end_time, '') | string %}
                   {% set ev_msg = event.summary | default(event.message, '') | string %}
                   {% if target_str in ev_start %}
                     {% if 'Travail' in ev_msg %}
                        {% set travail = true %}
                        {% set start_dt = ev_start | as_datetime %}
                        {% set end_dt = ev_end | as_datetime %}
                        {% set em = start_dt.strftime('%H:%M') if start_dt else '??' %}
                        {% set de = end_dt.strftime('%H:%M') if end_dt else '??' %}
                     {% endif %}
                   {% endif %}
                 {% endfor %}
               {% endif %}
               
               {% set hex = "ffffff" %}
               {% if i == 0 %}
                 {% set hex = "4d94ff" %}
               {% elif target_dt.strftime('%w') == '0' %}
                 {% set hex = "ffa500" if not travail else "ff4d4d" %}
               {% elif not travail %}
                 {% set hex = "4cd964" %}
               {% elif em != "" and ((em[:2]|int < 9) or (em[:2]|int == 9 and em[3:5]|int == 0)) %}
                 {% set hex = "ff8888" %}
               {% endif %}
               
               {% set ligne = "#" ~ hex ~ " " ~ j_name ~ " : " ~ (em ~ "-" ~ de if travail else "Repos") ~ "#" %}
               {% if i == 0 %}
                 {% set ns.texte = ligne %}
               {% else %}
                 {% set ns.texte = ns.texte ~ "\n" ~ ligne %}
               {% endif %}
            {% endfor %}
            {{ ns.texte }}
          {% endif %}
        couleur: >
          {% set alerte = states('sensor.VOTRE_DEPARTEMENT_weather_alert') %}
          {% if alerte == 'Rouge' %} Rouge
          {% elif alerte == 'Orange' %} Orange
          {% else %} Blanc {% endif %}

    # ====== 8. PREVISIONS HORAIRES (BULK - 3 chunks au lieu de 1) ======
    - action: weather.get_forecasts
      continue_on_error: true
      data:
        type: hourly
      target:
        entity_id: weather.VOTRE_VILLE
      response_variable: hourly_var_tab5
    - action: esphome.tab5_ha_hmi_tab5_maj_previsions_heures_bulk
      continue_on_error: true
      data:
        payload: >
          {% set fcasts = hourly_var_tab5.get('weather.VOTRE_VILLE', {}).get('forecast', []) if hourly_var_tab5 is defined else [] %}
          {% set ns = namespace(result="") %}
          {% for i in range(0, 5) %}
            {% if i < fcasts|length %}
              {% set dt = fcasts[i].datetime | as_datetime %}
              {% set heure_texte = dt.strftime('%H:00') if dt else '00:00' %}
              {% set condition = fcasts[i].condition | default('unknown') %}
              {% set temp = fcasts[i].temperature | float(0) %}
              {% set pluvio = fcasts[i].precipitation | float(0) %}
            {% else %}
              {% set heure_texte = '00:00' %}
              {% set condition = 'unknown' %}
              {% set temp = 0 %}
              {% set pluvio = 0 %}
            {% endif %}
            {% set ns.result = ns.result ~ i ~ "|" ~ heure_texte ~ "|" ~ condition ~ "|" ~ temp ~ "|" ~ pluvio ~ ";" %}
          {% endfor %}
          {{ ns.result }}
    - delay: "00:00:01"
    - action: esphome.tab5_ha_hmi_tab5_maj_previsions_heures_bulk
      continue_on_error: true
      data:
        payload: >
          {% set fcasts = hourly_var_tab5.get('weather.VOTRE_VILLE', {}).get('forecast', []) if hourly_var_tab5 is defined else [] %}
          {% set ns = namespace(result="") %}
          {% for i in range(5, 10) %}
            {% if i < fcasts|length %}
              {% set dt = fcasts[i].datetime | as_datetime %}
              {% set heure_texte = dt.strftime('%H:00') if dt else '00:00' %}
              {% set condition = fcasts[i].condition | default('unknown') %}
              {% set temp = fcasts[i].temperature | float(0) %}
              {% set pluvio = fcasts[i].precipitation | float(0) %}
            {% else %}
              {% set heure_texte = '00:00' %}
              {% set condition = 'unknown' %}
              {% set temp = 0 %}
              {% set pluvio = 0 %}
            {% endif %}
            {% set ns.result = ns.result ~ i ~ "|" ~ heure_texte ~ "|" ~ condition ~ "|" ~ temp ~ "|" ~ pluvio ~ ";" %}
          {% endfor %}
          {{ ns.result }}
    - delay: "00:00:01"
    - action: esphome.tab5_ha_hmi_tab5_maj_previsions_heures_bulk
      continue_on_error: true
      data:
        payload: >
          {% set fcasts = hourly_var_tab5.get('weather.VOTRE_VILLE', {}).get('forecast', []) if hourly_var_tab5 is defined else [] %}
          {% set ns = namespace(result="") %}
          {% for i in range(10, 15) %}
            {% if i < fcasts|length %}
              {% set dt = fcasts[i].datetime | as_datetime %}
              {% set heure_texte = dt.strftime('%H:00') if dt else '00:00' %}
              {% set condition = fcasts[i].condition | default('unknown') %}
              {% set temp = fcasts[i].temperature | float(0) %}
              {% set pluvio = fcasts[i].precipitation | float(0) %}
            {% else %}
              {% set heure_texte = '00:00' %}
              {% set condition = 'unknown' %}
              {% set temp = 0 %}
              {% set pluvio = 0 %}
            {% endif %}
            {% set ns.result = ns.result ~ i ~ "|" ~ heure_texte ~ "|" ~ condition ~ "|" ~ temp ~ "|" ~ pluvio ~ ";" %}
          {% endfor %}
          {{ ns.result }}


- id: tab5_volet_updater
  alias: "Sync Tab5 Volet Serre"
  mode: queued
  trigger:
    - platform: state
      entity_id: input_text.volet_serre_etat
    - platform: state
      entity_id: input_boolean.volet_serre_mouvement
  action:
    - action: esphome.tab5_ha_hmi_tab5_maj_volet_etat
      continue_on_error: true
      data:
        etat_physique: >
          {% if is_state('input_boolean.volet_serre_mouvement', 'on') %}
            En_mouvement
          {% else %}
            {{ states('input_text.volet_serre_etat') }}
          {% endif %}

- id: tab5_screen_presence_wifi
  alias: "Allumage/Extinction Ecran Tab5 selon WiFi Portable et Capteur Présence"
  description: "Active ou desactive le retroeclairage selon la presence du telephone et du capteur de présence"
  mode: single
  trigger:
    - platform: state
      entity_id: device_tracker.VOTRE_TELEPHONE
      to: 'home'
      id: "connecte"
    - platform: state
      entity_id: binary_sensor.VOTRE_CAPTEUR_PRESENCE
      to: 'on'
      id: "connecte"
    - platform: state
      entity_id: device_tracker.VOTRE_TELEPHONE
      to: 'not_home'
      id: "deconnecte"
    - platform: state
      entity_id: binary_sensor.VOTRE_CAPTEUR_PRESENCE
      to: 'off'
      id: "deconnecte"
  condition:
    - condition: state
      entity_id: input_boolean.is_primary_active
      state: "on"
  action:
    - choose:
        - conditions:
            - condition: trigger
              id: "connecte"
          sequence:
            - action: light.turn_on
              target:
                entity_id: light.m5stack_tab5_home_assistant_hmi_display_backlight
        - conditions:
            - condition: trigger
              id: "deconnecte"
          sequence:
            - action: light.turn_off
              target:
                entity_id: light.m5stack_tab5_home_assistant_hmi_display_backlight

